# DocVerify AI — Environment Configuration
# Copy this to .env and fill in your values. Never commit .env.

# Supabase PostgreSQL (Session pooler URL recommended for serverless)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# CORS — add your Netlify URL after deployment
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gemini Vision (comma-separated for failover; never commit real keys)
GEMINI_API_KEYS=key1,key2,key3,key4
GEMINI_MODEL=gemini-3-flash

# EasyOCR (set to true if GPU available)
EASYOCR_GPU=false

# API key for protected endpoints (optional — frontend sends X-Api-Key)
API_KEY=

# Upload limits
MAX_UPLOAD_BYTES=10485760
PDF_MAX_PAGES=3
GEMINI_PDF_PAGES=1
MAX_IMAGE_DIMENSION=2048
GEMINI_MAX_IMAGE_DIMENSION=768

# Email (optional — experience letter verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ENABLE_REPLY_POLLING=false
ENABLE_SCRAPER=false
