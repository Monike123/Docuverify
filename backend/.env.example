# ═══════════════════════════════════════════════════════════════════════
# DocVerify AI — Backend Environment Variables
# Copy this to .env for local development (never commit .env to git)
# Set these as Secrets in HF Space → Settings → Variables and secrets
# ═══════════════════════════════════════════════════════════════════════

# ── Database (Supabase) ───────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Session pooler connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────
# Add your Netlify URL after deploying frontend
CORS_ORIGINS=https://YOUR-SITE.netlify.app,https://monike123-extraction-validate.hf.space

# ── Gemini AI (5-key pool for 5000 free requests/day) ─────────────────
# Primary key
GEMINI_API_KEY=AQ.your_primary_key_here
# Failover pool — comma-separated, no spaces
GEMINI_API_KEYS=AQ.key2,AQ.key3,AQ.key4,AQ.key5
# Model: gemini-3-flash = 1000 RPD free, agentic vision, 1M context
GEMINI_MODEL=gemini-3-flash
# Image resolution sent to Gemini (1024 = sharp enough, tokens efficient)
GEMINI_MAX_IMAGE_DIMENSION=1024
# PDF DPI for rendering pages to images before Gemini analysis
GEMINI_PDF_DPI=150

# ── Upload Limits ─────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
EASYOCR_GPU=false

# ── Optional API Key (demo protection) ───────────────────────────────
API_KEY=

# ── SMTP (for experience letter email verification) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=manassawant5913@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
